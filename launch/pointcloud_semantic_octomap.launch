<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="rviz" default="true"/>

  <arg name="input_cloud_topic" default="/quad0_pcl_render_node/cloud"/>
  <arg name="input_odom_topic" default="/quad_0/lidar_slam/odom"/>
  <arg name="output_cloud_topic" default="/semantic_pcl/semantic_pcl"/>
  <arg name="world_frame_id" default="world"/>
  <arg name="sensor_frame_id" default="semantic_sensor"/>
  <arg name="octomap_resolution" default="0.4"/>
  <arg name="octomap_max_range" default="15.0"/>
  <arg name="octomap_raycast_range" default="10.0"/>
  <arg name="min_ground_z" default="1.0"/>
  <arg name="max_ground_z" default="3.5"/>
  <arg name="save_path" default="/tmp/semantic_map.ot"/>

  <rosparam file="$(find semantic_octomap)/params/octomap_generator.yaml" command="load"/>
  <param name="/octomap/pointcloud_topic" value="$(arg output_cloud_topic)"/>
  <param name="/octomap/world_frame_id" value="$(arg world_frame_id)"/>
  <param name="/octomap/resolution" value="$(arg octomap_resolution)"/>
  <param name="/octomap/max_range" value="$(arg octomap_max_range)"/>
  <param name="/octomap/raycast_range" value="$(arg octomap_raycast_range)"/>
  <param name="/octomap/min_ground_z" value="$(arg min_ground_z)"/>
  <param name="/octomap/max_ground_z" value="$(arg max_ground_z)"/>
  <param name="/octomap/save_path" value="$(arg save_path)"/>

  <node pkg="semantic_octomap"
        type="pointcloud_semantic_cloud_bridge_node"
        name="pointcloud_semantic_cloud_bridge"
        output="screen">
    <rosparam file="$(find semantic_octomap)/params/pointcloud_semantic_bridge.yaml" command="load"/>
    <rosparam subst_value="true">
      input_cloud_topic: $(arg input_cloud_topic)
      input_odom_topic: $(arg input_odom_topic)
      output_cloud_topic: $(arg output_cloud_topic)
      world_frame_id: $(arg world_frame_id)
      sensor_frame_id: $(arg sensor_frame_id)
    </rosparam>
  </node>

  <node pkg="semantic_octomap" type="semantic_octomap_node" name="semantic_octomap" output="screen"/>

  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz" args="-d $(find semantic_octomap)/rviz/config.rviz"/>

</launch>
